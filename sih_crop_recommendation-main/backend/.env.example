# Backend Environment Variables Template
# Copy this to .env and fill in your actual values

# Server Configuration
PORT=5000
NODE_ENV=development

# Database (for production, use MongoDB Atlas)
MONGODB_URI=mongodb://localhost:27017/sih_db
# Production example: mongodb+srv://username:password@cluster.mongodb.net/smart-crop?retryWrites=true&w=majority

# JWT Secret (generate a strong random string for production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
# Production: set to your domain or * for all origins

# ML Service (if using external ML API)
ML_API_URL=http://localhost:8000